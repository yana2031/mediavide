---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
	</head>

	<body>
		<Header />
		<div class="article-layout">
			<main>
				<article>
					<!-- Breadcrumb -->
					<nav class="breadcrumb" aria-label="パンくずリスト">
						<a href="/">ホーム</a>
						<span aria-hidden="true">›</span>
						<a href="/blog/">記事一覧</a>
						<span aria-hidden="true">›</span>
						<span class="current">{title}</span>
					</nav>

					<!-- Hero Image -->
					{heroImage && (
						<div class="hero-image">
							<Image width={900} height={450} src={heroImage} alt={title} />
						</div>
					)}

					<!-- Article Header -->
					<header class="article-header">
						<div class="article-meta">
							<time class="pub-date">
								<FormattedDate date={pubDate} />
							</time>
							{updatedDate && (
								<span class="updated-date">
									最終更新：<FormattedDate date={updatedDate} />
								</span>
							)}
						</div>
						<h1>{title}</h1>
						{description && <p class="article-desc">{description}</p>}
					</header>

					<hr class="divider" />

					<!-- Article Body -->
					<div class="prose">
						<slot />
					</div>

					<!-- Article Footer -->
					<div class="article-footer">
						<a href="/blog/" class="back-link">← 記事一覧に戻る</a>
					</div>
				</article>
			</main>

			<!-- Sidebar -->
			<aside class="sidebar">
				<div class="sidebar-widget">
					<h3 class="widget-title">📂 カテゴリー</h3>
					<ul class="widget-list">
						<li><a href="/blog/">講座比較・レビュー</a></li>
						<li><a href="/blog/">独学 vs 通信講座</a></li>
						<li><a href="/blog/">社会人の学習法</a></li>
						<li><a href="/blog/">eラーニング紹介</a></li>
						<li><a href="/blog/">在宅で取れる資格</a></li>
					</ul>
				</div>
				<div class="sidebar-widget">
					<h3 class="widget-title">📌 このサイトについて</h3>
					<p class="widget-text">オンライン資格講座の比較・レビュー情報を発信。社会人の資格取得を応援するメディアです。</p>
					<a href="/about/" class="widget-link">詳しく見る →</a>
				</div>
			</aside>
		</div>
		<Footer />
	</body>
</html>

<style>
	.article-layout {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 2.5rem;
		align-items: start;
	}

	/* Breadcrumb */
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.4em;
		font-size: 0.82rem;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
	}
	.breadcrumb a {
		color: var(--color-text-muted);
		text-decoration: none;
	}
	.breadcrumb a:hover { color: var(--color-primary); }
	.breadcrumb .current {
		color: var(--color-text);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 200px;
	}

	/* Hero Image */
	.hero-image {
		margin-bottom: 1.75rem;
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-md);
	}
	.hero-image :global(img) {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 0;
	}

	/* Article Header */
	.article-header {
		margin-bottom: 1.5rem;
	}
	.article-meta {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		margin-bottom: 0.9rem;
		flex-wrap: wrap;
	}
	.pub-date {
		font-size: 0.85rem;
		color: var(--color-text-muted);
		font-weight: 500;
	}
	.updated-date {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		font-style: italic;
	}
	.article-header h1 {
		font-size: clamp(1.4rem, 3.5vw, 2rem);
		line-height: 1.45;
		margin-bottom: 0.75rem;
	}
	.article-desc {
		font-size: 1rem;
		color: var(--color-text-muted);
		line-height: 1.7;
		border-left: 3px solid var(--color-primary);
		padding-left: 1em;
		margin: 0;
	}

	.divider {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: 1.75rem 0;
	}

	/* Article Body */
	.prose {
		font-size: 1.0625rem;
		line-height: 1.9;
		color: var(--color-text);
	}
	.prose :global(h2) {
		font-size: 1.35rem;
		margin-top: 2.5em;
		padding-bottom: 0.4em;
		border-bottom: 2px solid var(--color-border);
	}
	.prose :global(h3) {
		font-size: 1.15rem;
		margin-top: 2em;
		padding-left: 0.75em;
		border-left: 4px solid var(--color-primary);
	}
	.prose :global(p) { margin-bottom: 1.5em; }
	.prose :global(ul), .prose :global(ol) {
		padding-left: 1.5em;
		margin-bottom: 1.5em;
	}
	.prose :global(li) { margin-bottom: 0.5em; }
	.prose :global(strong) { color: var(--color-text); }

	/* Article Footer */
	.article-footer {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
	}
	.back-link {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--color-primary);
		text-decoration: none;
	}
	.back-link:hover { text-decoration: underline; }

	/* Sidebar */
	.sidebar {
		position: sticky;
		top: 80px;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.sidebar-widget {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 1.25rem;
	}
	.widget-title {
		font-size: 0.9rem;
		font-weight: 700;
		margin-bottom: 0.9rem;
		padding-bottom: 0.6rem;
		border-bottom: 2px solid var(--color-primary);
		color: var(--color-text);
	}
	.widget-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.widget-list a {
		font-size: 0.875rem;
		color: var(--color-text);
		text-decoration: none;
		display: block;
		padding: 0.35em 0.5em;
		border-radius: var(--radius-sm);
		transition: background 0.12s, color 0.12s;
	}
	.widget-list a:hover {
		background: var(--color-primary-light);
		color: var(--color-primary);
		text-decoration: none;
	}
	.widget-text {
		font-size: 0.85rem;
		color: var(--color-text-muted);
		line-height: 1.7;
		margin-bottom: 0.75rem;
	}
	.widget-link {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-primary);
	}

	@media (max-width: 860px) {
		.article-layout {
			grid-template-columns: 1fr;
		}
		.sidebar {
			position: static;
			display: grid;
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 560px) {
		.article-layout { padding: 1.5rem 1rem 3rem; }
		.sidebar { grid-template-columns: 1fr; }
		.breadcrumb .current { max-width: 140px; }
	}
</style>
