---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../consts';

interface HeadingItem {
	depth: number;
	slug: string;
	text: string;
}

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: HeadingItem[];
	readingTime?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	headings = [],
	readingTime,
} = Astro.props;

const categoryLabel = category ? CATEGORIES[category] : null;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// Sidebar: 新着・人気記事（現在の記事を除く）
const currentPath = Astro.url.pathname;
const allPosts = await getCollection('blog');

const recentPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.filter(p => {
		const id = p.id.replace(/\\/g, '/');
		const slug = id.split('/').pop();
		return `/${p.data.category}/${slug}/` !== currentPath;
	})
	.slice(0, 5);

// 人気記事: pubDate昇順（記事が増えたら analytics に差し替え可）
const popularPosts = allPosts
	.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf())
	.filter(p => {
		const id = p.id.replace(/\\/g, '/');
		const slug = id.split('/').pop();
		return `/${p.data.category}/${slug}/` !== currentPath;
	})
	.slice(0, 5);

// Breadcrumb JSON-LD
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const breadcrumbItems = [
	{ position: 1, name: 'ホーム', item: `${siteUrl}/` },
	...(category && categoryLabel
		? [{ position: 2, name: categoryLabel, item: `${siteUrl}/${category}/` }]
		: []),
	{ position: category ? 3 : 2, name: title, item: `${siteUrl}${Astro.url.pathname}` },
];
const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbItems.map(b => ({
		'@type': 'ListItem',
		position: b.position,
		name: b.name,
		item: b.item,
	})),
};
---

<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
			section={categoryLabel ?? undefined}
		/>
		<!-- BreadcrumbList JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
	</head>

	<body>
		<Header />
		<div class="article-layout">
			<main>
				<article
					itemscope
					itemtype="https://schema.org/Article"
				>
					<!-- Breadcrumb -->
					<nav class="breadcrumb" aria-label="パンくずリスト">
						<a href="/">ホーム</a>
						{category && categoryLabel && (
							<>
								<span aria-hidden="true">›</span>
								<a href={`/${category}/`}>{categoryLabel}</a>
							</>
						)}
						<span aria-hidden="true">›</span>
						<span class="current" aria-current="page">{title}</span>
					</nav>

					<!-- Article Header -->
					<header class="article-header">
						{category && categoryLabel && (
							<a href={`/${category}/`} class="category-chip">{categoryLabel}</a>
						)}
						<div class="article-meta">
							<time
								class="pub-date"
								itemprop="datePublished"
								datetime={pubDate.toISOString()}
							>
								<FormattedDate date={pubDate} />
							</time>
							{updatedDate && (
								<time
									class="updated-date"
									itemprop="dateModified"
									datetime={updatedDate.toISOString()}
								>
									最終更新：<FormattedDate date={updatedDate} />
								</time>
							)}
							{readingTime && (
								<span class="reading-time">🕐 約{readingTime}分</span>
							)}
						</div>
						<h1 itemprop="headline">{title}</h1>
						{description && (
							<p class="article-desc" itemprop="description">{description}</p>
						)}
					</header>

					<!-- Hero Image -->
					{heroImage && (
						<div class="hero-image">
							<img src={heroImage} alt={title} itemprop="image" loading="eager" />
						</div>
					)}

					<!-- TOC（モバイル用：本文前） -->
					{tocHeadings.length >= 3 && (
						<nav class="toc-mobile" aria-label="目次">
							<p class="toc-title">📋 目次</p>
							<ol class="toc-list">
								{tocHeadings.map(h => (
									<li class:list={[`toc-item`, `toc-h${h.depth}`]}>
										<a href={`#${h.slug}`}>{h.text}</a>
									</li>
								))}
							</ol>
						</nav>
					)}

					<hr class="divider" />

					<!-- Article Body -->
					<div class="prose" itemprop="articleBody">
						<slot />
					</div>

					<!-- Article Footer -->
					<div class="article-footer">
						{category && categoryLabel && (
							<a href={`/${category}/`} class="footer-link">
								← {categoryLabel}の記事一覧
							</a>
						)}
						<a href="/" class="footer-link footer-link-muted">ホームに戻る</a>
					</div>

					<!-- hidden microdata -->
					<span itemprop="author" itemscope itemtype="https://schema.org/Organization" hidden>
						<span itemprop="name">{SITE_TITLE}</span>
					</span>
					<span itemprop="publisher" itemscope itemtype="https://schema.org/Organization" hidden>
						<span itemprop="name">{SITE_TITLE}</span>
					</span>
				</article>
			</main>

			<!-- Sidebar -->
			<aside class="sidebar" aria-label="サイドバー">
				<!-- TOC（デスクトップ用） -->
				{tocHeadings.length >= 3 && (
					<div class="sidebar-widget toc-widget">
						<h3 class="widget-title">📋 目次</h3>
						<nav aria-label="目次">
							<ol class="toc-list">
								{tocHeadings.map(h => (
									<li class:list={[`toc-item`, `toc-h${h.depth}`]}>
										<a href={`#${h.slug}`}>{h.text}</a>
									</li>
								))}
							</ol>
						</nav>
					</div>
				)}

				<!-- 新着記事 Widget -->
				{recentPosts.length > 0 && (
					<div class="sidebar-widget">
						<h3 class="widget-title">🆕 新着記事</h3>
						<ul class="article-list">
							{recentPosts.map(p => {
								const sid = p.id.replace(/\\/g, '/').split('/').pop();
								return (
									<li class="article-list-item">
										<a href={`/${p.data.category}/${sid}/`} class="article-list-link">
											{p.data.heroImage
												? <img src={p.data.heroImage} alt={p.data.title} class="article-list-thumb" loading="lazy" />
												: <div class="article-list-thumb article-list-thumb--placeholder" />
											}
											<div class="article-list-body">
												<span class="article-list-title">{p.data.title}</span>
												<span class="article-list-date">
													<FormattedDate date={p.data.pubDate} />
												</span>
											</div>
										</a>
									</li>
								);
							})}
						</ul>
					</div>
				)}

				<!-- 人気記事 Widget -->
				{popularPosts.length > 0 && (
					<div class="sidebar-widget">
						<h3 class="widget-title">🔥 人気記事</h3>
						<ul class="article-list">
							{popularPosts.map((p, i) => {
								const sid = p.id.replace(/\\/g, '/').split('/').pop();
								return (
									<li class="article-list-item">
										<a href={`/${p.data.category}/${sid}/`} class="article-list-link">
											<span class="article-list-rank">{i + 1}</span>
											<div class="article-list-body">
												<span class="article-list-title">{p.data.title}</span>
												<span class="article-list-date">
													<FormattedDate date={p.data.pubDate} />
												</span>
											</div>
										</a>
									</li>
								);
							})}
						</ul>
					</div>
				)}

				<!-- Category Widget -->
				<div class="sidebar-widget">
					<h3 class="widget-title">📂 カテゴリー</h3>
					<ul class="widget-list">
						{Object.entries(CATEGORIES).map(([slug, label]) => (
							<li>
								<a
									href={`/${slug}/`}
									class:list={[{ active: slug === category }]}
									aria-current={slug === category ? 'page' : undefined}
								>
									{label}
								</a>
							</li>
						))}
					</ul>
				</div>

				<!-- About Widget -->
				<div class="sidebar-widget">
					<h3 class="widget-title">📌 サイトについて</h3>
					<p class="widget-text">オンライン資格講座の比較・レビュー情報を発信。社会人の資格取得を応援するメディアです。</p>
					<a href="/about/" class="widget-link">詳しく見る →</a>
				</div>
			</aside>
		</div>
		<Footer />
	</body>
</html>

<script>
// スクロールフェードイン + マーカーアニメーション
(function () {
  const FADE_TARGETS = '.prose p, .prose h2, .prose h3, .prose blockquote, .prose table, .prose img, .prose ul, .prose ol';

  const els = Array.from(document.querySelectorAll(FADE_TARGETS));
  if (!els.length) return;

  // 初期状態を非表示に
  els.forEach(el => el.classList.add('fade-el'));

  function revealEl(el: Element, delay = 0) {
    (el as HTMLElement).style.transitionDelay = delay + 'ms';
    el.classList.add('is-visible');

    // マーカー対象は p と li 内の strong のみ（blockquote 内は除外）
    if (el.tagName === 'P' || el.tagName === 'LI' || el.tagName === 'UL' || el.tagName === 'OL') {
      el.querySelectorAll<HTMLElement>('p strong, li strong').forEach((s, i) => {
        setTimeout(() => s.classList.add('mark-in'), delay + 280 + i * 140);
      });
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          revealEl(entry.target);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -36px 0px' }
  );

  // 初期表示領域内の要素はページロード直後にスタガー表示
  let batch = 0;
  els.forEach(el => {
    const rect = el.getBoundingClientRect();
    if (rect.top < window.innerHeight + 40) {
      revealEl(el, batch * 70);
      batch++;
    } else {
      observer.observe(el);
    }
  });
})();
</script>

<style>
	.article-layout {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 2.5rem;
		align-items: start;
	}

	main { width: 100%; max-width: none; margin: 0; padding: 0; min-width: 0; }

	/* Breadcrumb */
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.4em;
		font-size: 0.82rem;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
	}
	.breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
	.breadcrumb a:hover { color: var(--color-primary); }
	.breadcrumb .current {
		color: var(--color-text);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 220px;
	}

	/* Hero */
	.hero-image {
		margin-bottom: 1.75rem;
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-md);
	}
	.hero-image :global(img) { width: 100%; height: auto; display: block; border-radius: 0; }

	/* Article Header */
	.article-header { margin-bottom: 1.5rem; }
	.category-chip {
		display: inline-block;
		background: var(--color-primary-light);
		color: var(--color-primary);
		font-size: 0.78rem;
		font-weight: 700;
		padding: 0.25em 0.85em;
		border-radius: 999px;
		text-decoration: none;
		margin-bottom: 0.9rem;
		transition: background 0.15s, color 0.15s;
	}
	.category-chip:hover { background: var(--color-primary); color: #fff; text-decoration: none; }

	.article-meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 0.9rem;
		flex-wrap: wrap;
	}
	.pub-date { font-size: 0.85rem; color: var(--color-text-muted); font-weight: 500; }
	.updated-date { font-size: 0.8rem; color: var(--color-text-muted); font-style: italic; }
	.reading-time { font-size: 0.82rem; color: var(--color-text-muted); }

	.article-header h1 {
		font-size: clamp(1.4rem, 3.5vw, 2rem);
		line-height: 1.45;
		margin-bottom: 0.75rem;
	}
	.article-desc {
		font-size: 1rem;
		color: var(--color-text-muted);
		line-height: 1.7;
		border-left: 3px solid var(--color-primary);
		padding-left: 1em;
		margin: 0;
	}

	/* TOC Mobile（本文前、スマホのみ） */
	.toc-mobile {
		background: var(--color-primary-light);
		border: 1px solid #bfdbfe;
		border-radius: var(--radius-md);
		padding: 1rem 1.25rem;
		margin-bottom: 1.5rem;
		display: none;
	}
	.toc-title {
		font-size: 0.9rem;
		font-weight: 700;
		margin: 0 0 0.6rem;
		color: var(--color-primary);
	}

	/* TOC共通 */
	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		counter-reset: toc-counter;
	}
	.toc-item { margin-bottom: 0.3rem; }
	.toc-item a {
		font-size: 0.83rem;
		color: var(--color-text);
		text-decoration: none;
		line-height: 1.5;
		display: block;
		padding: 0.2em 0;
		transition: color 0.12s;
	}
	.toc-item a:hover { color: var(--color-primary); text-decoration: none; }
	.toc-h3 { padding-left: 1em; }
	.toc-h3 a { font-size: 0.8rem; color: var(--color-text-muted); }
	.toc-h3 a:hover { color: var(--color-primary); }

	.divider { border: none; border-top: 1px solid var(--color-border); margin: 1.75rem 0; }

	/* Article Body */
	.prose { font-size: 1.0625rem; line-height: 1.9; color: var(--color-text); }

	/* h2: 左アクセントバー + グラデーション背景 */
	.prose :global(h2) {
		font-size: 1.35rem;
		margin-top: 2.75em;
		margin-bottom: 1em;
		padding: 0.65em 1.1em;
		background: linear-gradient(to right, var(--color-primary-light) 0%, rgba(239,246,255,0) 80%);
		border-left: 5px solid var(--color-primary);
		border-radius: 0 var(--radius-md) var(--radius-md) 0;
		scroll-margin-top: 80px;
		color: var(--color-text);
	}

	/* h3: アクセントカラー左バー + 薄い背景 */
	.prose :global(h3) {
		font-size: 1.12rem;
		margin-top: 2em;
		margin-bottom: 0.75em;
		padding: 0.4em 0.9em;
		border-left: 3px solid var(--color-accent);
		background: #fffbeb;
		border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
		scroll-margin-top: 80px;
		color: var(--color-text);
	}

	/* strong: プライマリカラーで強調 */
	.prose :global(strong) {
		color: var(--color-primary-dark);
		font-weight: 700;
	}

	.prose :global(p) { margin-bottom: 1.5em; }

	/* ul: カラードット */
	.prose :global(ul) {
		list-style: none;
		padding-left: 1.5em;
		margin-bottom: 1.5em;
	}
	.prose :global(ul li) {
		position: relative;
		padding-left: 0.25em;
		margin-bottom: 0.5em;
	}
	.prose :global(ul li)::before {
		content: '';
		position: absolute;
		left: -1.1em;
		top: 0.7em;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-primary);
	}

	/* ol: 番号をプライマリカラーで */
	.prose :global(ol) {
		padding-left: 1.75em;
		margin-bottom: 1.5em;
	}
	.prose :global(ol li) {
		margin-bottom: 0.5em;
		padding-left: 0.25em;
	}
	.prose :global(ol li::marker) {
		color: var(--color-primary);
		font-weight: 700;
	}

	.prose :global(img) {
		width: 100%;
		height: auto;
		border-radius: var(--radius-md);
		margin: 1.75em 0;
		display: block;
		box-shadow: var(--shadow-sm);
	}

	/* Callout box（blockquote → "この記事でわかること" など） */
	.prose :global(blockquote) {
		background: var(--color-primary-light);
		border-left: 4px solid var(--color-primary);
		border-radius: 0 var(--radius-md) var(--radius-md) 0;
		padding: 1rem 1.25rem;
		margin: 1.75em 0;
		color: var(--color-text);
	}
	.prose :global(blockquote p) { margin-bottom: 0.4em; }
	.prose :global(blockquote p:last-child) { margin-bottom: 0; }
	.prose :global(blockquote strong) { color: var(--color-primary); }
	.prose :global(blockquote ul) { margin: 0.5em 0 0; padding-left: 1.4em; }
	.prose :global(blockquote li) { font-size: 0.95rem; margin-bottom: 0.3em; }

	/* Table */
	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1.75em 0;
		font-size: 0.9rem;
		display: block;
		overflow-x: auto;
	}
	.prose :global(th) {
		background: var(--color-primary);
		color: #fff;
		padding: 0.65em 1em;
		text-align: left;
		font-weight: 700;
		white-space: nowrap;
	}
	.prose :global(td) {
		padding: 0.65em 1em;
		border: 1px solid var(--color-border);
		vertical-align: top;
	}
	.prose :global(tr:nth-child(even) td) { background: var(--color-primary-light); }

	/* FAQ section（## よくある質問 の中の h3 Q: 形式） */
	.prose :global(h3):has(+ p) {
		margin-top: 1.5em;
	}

	/* ── スクロールフェードイン ── */
	.prose :global(.fade-el) {
		opacity: 0;
		transform: translateY(26px);
		transition:
			opacity 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94),
			transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}
	.prose :global(.fade-el.is-visible) {
		opacity: 1;
		transform: translateY(0);
	}

	/* ── アニメーションマーカー ── */
	.prose :global(p strong),
	.prose :global(li strong) {
		background-image: linear-gradient(transparent 58%, rgba(255, 213, 79, 0.6) 58%);
		background-repeat: no-repeat;
		background-size: 0% 100%;
		background-position: left center;
		padding-bottom: 0.06em;
		transition: background-size 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}
	.prose :global(p strong.mark-in),
	.prose :global(li strong.mark-in) {
		background-size: 100% 100%;
	}

	/* Article Footer */
	.article-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
	}
	.footer-link {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--color-primary);
		text-decoration: none;
	}
	.footer-link:hover { text-decoration: underline; }
	.footer-link-muted { color: var(--color-text-muted); font-weight: 400; }

	/* Sidebar */
	.sidebar {
		position: sticky;
		top: 80px;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		max-height: calc(100vh - 96px);
		overflow-y: auto;
		scrollbar-width: thin;
		min-width: 0;
	}
	.sidebar-widget {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 1.25rem;
	}
	.toc-widget { background: var(--color-primary-light); border-color: #bfdbfe; }
	.widget-title {
		font-size: 0.9rem;
		font-weight: 700;
		margin: 0 0 0.9rem;
		padding-bottom: 0.6rem;
		border-bottom: 2px solid var(--color-primary);
		color: var(--color-text);
	}
	.widget-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; }
	.widget-list a {
		font-size: 0.875rem;
		color: var(--color-text);
		text-decoration: none;
		display: block;
		padding: 0.35em 0.6em;
		border-radius: var(--radius-sm);
		transition: background 0.12s, color 0.12s;
	}
	.widget-list a:hover, .widget-list a.active {
		background: var(--color-primary-light);
		color: var(--color-primary);
		text-decoration: none;
	}
	.widget-list a.active { font-weight: 700; }
	.widget-text { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.7; margin-bottom: 0.75rem; }
