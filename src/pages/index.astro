---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 6);

const categories = [
	{ slug: 'shikaku-hikaku',      icon: '🏆', label: '資格・講座比較レビュー', desc: '人気講座を徹底比較' },
	{ slug: 'dokugaku-vs-tsushin', icon: '⚖️', label: '独学 vs 通信講座',       desc: 'あなたに合う方法を探す' },
	{ slug: 'shakaijin-study',     icon: '💼', label: '社会人の学習法',         desc: 'スキマ時間で合格へ' },
	{ slug: 'elearning',           icon: '💻', label: 'eラーニング紹介',        desc: 'おすすめサービスを紹介' },
	{ slug: 'zaitaku-shikaku',     icon: '🏠', label: '在宅で取れる資格',       desc: '人気資格ランキング' },
];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="hero">
			<div class="hero-inner">
				<p class="hero-badge">📚 資格取得を応援するメディア</p>
				<h1>オンライン資格講座を<br />比較・選ぶならここへ</h1>
				<p class="hero-desc">
					社会人の方でも無理なく続けられる講座を厳選紹介。<br />
					独学・通信・eラーニングの違いから、効率的な学習法まで発信しています。
				</p>
				<div class="hero-actions">
					<a href="/blog/" class="btn-primary">記事を読む</a>
					<a href="/about/" class="btn-secondary">サイトについて</a>
				</div>
			</div>
		</section>

		<main>
			<!-- Categories -->
			<section class="section">
				<h2 class="section-title">📂 カテゴリーから探す</h2>
				<ul class="category-grid">
					{categories.map(cat => (
						<li>
							<a href={`/category/${cat.slug}/`} class="category-card">
								<span class="category-icon">{cat.icon}</span>
								<span class="category-label">{cat.label}</span>
								<span class="category-desc">{cat.desc}</span>
							</a>
						</li>
					))}
				</ul>
			</section>

			<!-- Recent Articles -->
			{posts.length > 0 && (
				<section class="section">
					<h2 class="section-title">🆕 新着記事</h2>
					<div class="article-grid">
						{posts.map((post, i) => (
							<ArticleCard post={post} featured={i === 0} />
						))}
					</div>
					<div class="view-all">
						<a href="/blog/" class="btn-outline">すべての記事を見る →</a>
					</div>
				</section>
			)}
		</main>

		<Footer />
	</body>
</html>

<style>
	/* Hero */
	.hero {
		background: linear-gradient(135deg, #1e3a8a 0%, #1d4ed8 55%, #3b82f6 100%);
		color: #ffffff;
		padding: 4.5rem 1.5rem;
		text-align: center;
	}
	.hero-inner {
		max-width: 720px;
		margin: 0 auto;
	}
	.hero-badge {
		display: inline-block;
		background: rgba(255,255,255,0.15);
		border: 1px solid rgba(255,255,255,0.3);
		border-radius: 999px;
		padding: 0.3em 1em;
		font-size: 0.875rem;
		margin-bottom: 1.25rem;
	}
	.hero h1 {
		font-size: clamp(1.75rem, 5vw, 2.75rem);
		color: #ffffff;
		margin-bottom: 1rem;
		line-height: 1.35;
	}
	.hero-desc {
		font-size: clamp(0.95rem, 2vw, 1.1rem);
		color: rgba(255,255,255,0.85);
		line-height: 1.8;
		margin-bottom: 2rem;
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn-primary {
		background: var(--color-accent);
		color: #ffffff;
		font-weight: 700;
		padding: 0.75em 2em;
		border-radius: var(--radius-md);
		text-decoration: none;
		font-size: 1rem;
		transition: background 0.15s, transform 0.15s;
		display: inline-block;
	}
	.btn-primary:hover {
		background: var(--color-accent-dark);
		text-decoration: none;
		transform: translateY(-1px);
	}
	.btn-secondary {
		background: rgba(255,255,255,0.15);
		color: #ffffff;
		font-weight: 600;
		padding: 0.75em 2em;
		border-radius: var(--radius-md);
		border: 1px solid rgba(255,255,255,0.4);
		text-decoration: none;
		font-size: 1rem;
		transition: background 0.15s;
		display: inline-block;
	}
	.btn-secondary:hover {
		background: rgba(255,255,255,0.25);
		text-decoration: none;
	}

	/* Section */
	.section {
		margin-bottom: 3.5rem;
	}

	/* Categories */
	.category-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 0.75rem;
	}
	.category-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 0.4rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 1.25rem 0.75rem;
		text-decoration: none;
		transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
	}
	.category-card:hover {
		border-color: var(--color-primary);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
		text-decoration: none;
	}
	.category-icon {
		font-size: 1.75rem;
		line-height: 1;
	}
	.category-label {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--color-text);
		line-height: 1.3;
	}
	.category-desc {
		font-size: 0.72rem;
		color: var(--color-text-muted);
		line-height: 1.4;
	}

	/* Article Grid */
	.article-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}
	.article-grid > :global(.card:first-child) {
		grid-column: 1 / -1;
	}

	/* View all */
	.view-all {
		text-align: center;
		margin-top: 2rem;
	}
	.btn-outline {
		display: inline-block;
		padding: 0.75em 2.5em;
		border: 2px solid var(--color-primary);
		border-radius: var(--radius-md);
		color: var(--color-primary);
		font-weight: 700;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}
	.btn-outline:hover {
		background: var(--color-primary);
		color: #ffffff;
		text-decoration: none;
	}

	@media (max-width: 900px) {
		.article-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.article-grid > :global(.card:first-child) {
			grid-column: 1 / -1;
		}
		.category-grid {
			grid-template-columns: repeat(3, 1fr);
		}
		.category-card { padding: 1rem 0.6rem; }
	}
	@media (max-width: 600px) {
		.hero { padding: 3rem 1.25rem; }
		.article-grid {
			grid-template-columns: 1fr;
		}
		.article-grid > :global(.card:first-child) {
			grid-column: 1;
		}
		.category-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.category-grid li:last-child {
			grid-column: 1 / -1;
		}
	}
</style>
