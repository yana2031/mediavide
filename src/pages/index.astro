---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>資格・オンライン講座の比較メディア</h1>
				<p>社会人の資格取得を応援する情報サイト。オンライン講座の比較・レビューや、効率的な学習法を発信しています。</p>
			</section>
			<section class="recent-posts">
				<h2>新着記事</h2>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								<span class="title">{post.data.title}</span>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog/" class="all-posts">記事一覧を見る →</a>
			</section>
		</main>
		<Footer />
		<style>
			.hero {
				padding: 2em 0;
				text-align: center;
			}
			.hero h1 {
				font-size: 2rem;
				margin-bottom: 0.5em;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.1rem;
			}
			.recent-posts {
				max-width: 720px;
				margin: 2em auto;
				padding: 0 1em;
			}
			.recent-posts h2 {
				font-size: 1.4rem;
				border-bottom: 2px solid rgb(var(--accent));
				padding-bottom: 0.4em;
				margin-bottom: 1em;
			}
			.recent-posts ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.recent-posts li {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 0.8em 0;
			}
			.recent-posts a {
				display: flex;
				gap: 1em;
				align-items: baseline;
				text-decoration: none;
				color: inherit;
			}
			.recent-posts a:hover .title {
				text-decoration: underline;
			}
			.date {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			.all-posts {
				display: inline-block;
				margin-top: 1.2em;
				color: rgb(var(--accent));
				font-weight: bold;
				text-decoration: none;
			}
			.all-posts:hover {
				text-decoration: underline;
			}
		</style>
	</body>
</html>
