---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const title = `このサイトについて | ${SITE_TITLE}`;
const description = 'shikaku-online.com は、オンライン資格講座の比較・レビューを通じて、社会人の資格取得をサポートするメディアです。';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="about-wrap">
				<nav class="breadcrumb" aria-label="パンくずリスト">
					<a href="/">ホーム</a>
					<span aria-hidden="true">›</span>
					<span aria-current="page">サイトについて</span>
				</nav>

				<h1>このサイトについて</h1>

				<div class="about-body">
					<p>
						<strong>shikaku-online.com</strong> は、オンライン資格講座の比較・レビュー情報を発信するメディアです。
						社会人として忙しい日々を送りながらも、スキルアップや転職・昇進のために資格取得を目指す方を応援します。
					</p>

					<h2>扱うテーマ</h2>
					<ul>
						<li>オンライン資格講座の比較・レビュー</li>
						<li>独学 vs 通信講座のメリット・デメリット</li>
						<li>社会人が資格取得するコツ・学習法</li>
						<li>おすすめのeラーニングサービス紹介</li>
						<li>在宅で取れる人気資格ランキング</li>
					</ul>

					<h2>コンテンツについて</h2>
					<p>
						当サイトの記事は、最新のAI技術を活用して生成・更新されています。
						情報の正確性には細心の注意を払っていますが、講座の料金や内容は変更になる場合があります。
						最新情報は各サービスの公式サイトでご確認ください。
					</p>
				</div>

				<div class="about-footer">
					<a href="/" class="back-link">← ホームに戻る</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-wrap {
		max-width: 720px;
		margin: 0 auto;
	}
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.4em;
		font-size: 0.82rem;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
	}
	.breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
	.breadcrumb a:hover { color: var(--color-primary); }

	h1 {
		font-size: clamp(1.5rem, 4vw, 2rem);
		margin-bottom: 2rem;
		padding-bottom: 0.75rem;
		border-bottom: 2px solid var(--color-border);
	}
	.about-body { line-height: 1.9; }
	.about-body h2 {
		font-size: 1.2rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		padding-left: 0.75em;
		border-left: 4px solid var(--color-primary);
	}
	.about-body ul {
		padding-left: 1.5em;
		margin-bottom: 1.5rem;
	}
	.about-body li { margin-bottom: 0.4em; }

	.about-footer {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
	}
	.back-link {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--color-primary);
		text-decoration: none;
	}
	.back-link:hover { text-decoration: underline; }
</style>
