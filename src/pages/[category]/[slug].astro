---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => {
		const id = post.id.replace(/\\/g, '/');
		const slug = id.split('/').pop() ?? post.id;
		const category = post.data.category ?? id.split('/')[0];
		return {
			params: { category, slug },
			props: post,
		};
	});
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);

const rawBody: string = (post as any).body ?? '';
const charCount = rawBody.replace(/\s+/g, '').length;
const readingTime = Math.max(1, Math.ceil(charCount / 600));
---

<BlogPost {...post.data} headings={headings} readingTime={readingTime}>
	<Content />
</BlogPost>
