---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { CATEGORIES } from '../consts';

interface Props {
	post: CollectionEntry<'blog'>;
	featured?: boolean;
	headingLevel?: 2 | 3;
}

const { post, featured = false, headingLevel = 2 } = Astro.props;
const { title, description, pubDate, heroImage, category } = post.data;

const categoryLabel = category ? CATEGORIES[category] : null;
const HeadingTag = `h${headingLevel}` as 'h2' | 'h3';

const _id = post.id.replace(/\\/g, '/');
const _slug = _id.split('/').pop() ?? post.id;
const articleHref = category ? `/${category}/${_slug}/` : `/${_id}/`;

const gradients = [
	'linear-gradient(135deg, #1d4ed8 0%, #3b82f6 100%)',
	'linear-gradient(135deg, #065f46 0%, #10b981 100%)',
	'linear-gradient(135deg, #92400e 0%, #f59e0b 100%)',
	'linear-gradient(135deg, #4c1d95 0%, #8b5cf6 100%)',
	'linear-gradient(135deg, #9f1239 0%, #f43f5e 100%)',
];
const gradient = gradients[title.charCodeAt(0) % gradients.length];
---

<!-- overlay-link pattern: card-link is absolute overlay, no nesting of <a> tags -->
<article class:list={['card', { featured }]}>
	<div class="card-image">
		{heroImage
			? <Image src={heroImage} width={featured ? 800 : 400} height={featured ? 400 : 200} alt={title} />
			: <div class="card-gradient" style={`background: ${gradient}`}>
					<span class="card-gradient-icon">📝</span>
				</div>
		}
		{categoryLabel && category && (
			<a href={`/${category}/`} class="category-badge">
				{categoryLabel}
			</a>
		)}
	</div>
	<div class="card-body">
		<p class="card-date"><FormattedDate date={pubDate} /></p>
		<HeadingTag class="card-title">{title}</HeadingTag>
		{description && <p class="card-desc">{description}</p>}
		<span class="card-more">続きを読む →</span>
	</div>
	<!-- overlay covers the full card; category-badge sits above via z-index -->
	<a href={articleHref} class="card-link" aria-label={title}></a>
</article>

<style>
	.card {
		position: relative;
		background: var(--color-surface);
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		transition: box-shadow 0.2s, transform 0.2s;
		display: flex;
		flex-direction: column;
	}
	.card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }

	/* Full-card overlay link – sits below the badge via z-index */
	.card-link {
		position: absolute;
		inset: 0;
		z-index: 0;
	}
	.card-link:hover { text-decoration: none; }

	.card-image {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 8;
		overflow: hidden;
		flex-shrink: 0;
	}
	.card-image :global(img) { width: 100%; height: 100%; object-fit: cover; border-radius: 0; display: block; }
	.card-gradient { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
	.card-gradient-icon { font-size: 2.5rem; opacity: 0.7; }

	.category-badge {
		position: absolute;
		top: 0.6rem;
		left: 0.6rem;
		background: rgba(255,255,255,0.92);
		color: var(--color-primary);
		font-size: 0.7rem;
		font-weight: 700;
		padding: 0.25em 0.7em;
		border-radius: 999px;
		text-decoration: none;
		backdrop-filter: blur(4px);
		transition: background 0.15s, color 0.15s;
		z-index: 1;
	}
	.category-badge:hover { background: var(--color-primary); color: #fff; text-decoration: none; }

	.card-body {
		padding: 1.1rem 1.25rem 1.4rem;
		display: flex;
		flex-direction: column;
		flex: 1;
		position: relative;
		z-index: 0;
	}
	.card-date { font-size: 0.78rem; color: var(--color-text-muted); margin: 0 0 0.4rem; }
	.card-title {
		font-size: 0.975rem;
		font-weight: 700;
		line-height: 1.5;
		margin: 0 0 0.55rem;
		color: var(--color-text);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		transition: color 0.15s;
	}
	.card:hover .card-title { color: var(--color-primary); }
	.card-desc {
		font-size: 0.83rem;
		color: var(--color-text-muted);
		line-height: 1.6;
		margin: 0 0 0.9rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
	}
	.card-more { font-size: 0.82rem; font-weight: 700; color: var(--color-primary); margin-top: auto; }

	.featured .card-image { aspect-ratio: 16 / 7; }
	.featured .card-title { font-size: 1.15rem; -webkit-line-clamp: 2; }
	.featured .card-desc { -webkit-line-clamp: 3; }
</style>
